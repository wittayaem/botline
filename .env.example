# LINE Bot
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_GROUP_ID=C_your_group_id_here

# Server
PORT=3000
STORAGE_PATH=./storage
BASE_URL=https://your-domain.com

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=botline_user
DB_PASS=your_db_password
DB_NAME=botline

# OpenRouter AI
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_CHAT_MODEL=anthropic/claude-haiku-4-5

# Equipment DB API (it.pruksamoney.co.th)
EQUIPMENT_API_URL=https://it.pruksamoney.co.th/api/linebot_query.php
EQUIPMENT_API_SECRET=linebot_secret_pruksa_2025

# Dashboard
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password
SESSION_SECRET=change_this_long_random_secret_key
